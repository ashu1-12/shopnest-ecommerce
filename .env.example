# ╔════════════════════════════════════════════════════════════════╗
# ║  .env.example — Copy this to .env and fill in your values     ║
# ║  NEVER commit .env to Git — it contains secrets!              ║
# ╚════════════════════════════════════════════════════════════════╝

# ── RAZORPAY ─────────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys
# Test keys start with 'rzp_test_', live keys with 'rzp_live_'
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_SECRET_KEY=your_razorpay_secret_key
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_from_razorpay_dashboard

# ── JWT ───────────────────────────────────────────────────────────
# Must be at least 256 bits (32+ characters)
# Generate with: openssl rand -base64 64
JWT_SECRET=replace-this-with-a-very-long-random-string-at-least-256-bits

# ── EMAIL (for OTP + order notifications) ────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
# For Gmail: use App Password (not your real password)
# Enable at: Google Account → Security → App passwords
SMTP_PASSWORD=your-gmail-app-password

# ── SMS (Twilio) ─────────────────────────────────────────────────
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ── FIREBASE (Push Notifications) ────────────────────────────────
# Download firebase-adminsdk.json from Firebase Console
FIREBASE_CREDENTIALS_PATH=/secrets/firebase-adminsdk.json
